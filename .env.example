# PostgreSQL — must use Session Pooler URL for Railway IPv4 compatibility
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_token_here

# Google Drive Service Account (paste full JSON as single-line string)
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account","project_id":"..."}

# Google Drive root folder ID (shared with service account as Editor)
GOOGLE_DRIVE_ROOT_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# Railway container SHM size for PostgreSQL shared_buffers (500 MB)
RAILWAY_SHM_SIZE_BYTES=524288000

# Cron schedule for photo backup worker (UTC — 0 19 * * * = 03:00 Taipei time)
# NOTE: Must also be manually synced to Railway service Settings > Cron Schedule
PHOTO_BACKUP_CRON=0 19 * * *
